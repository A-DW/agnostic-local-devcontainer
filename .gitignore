# =============================================================================
# agnostic-local-devcontainer — multi-stack .gitignore baseline
# Covers: Node.js, Next.js, Vite, Python
# Extend this file to match your project's specific stack and tooling.
# =============================================================================

# -----------------------------------------------------------------------------
# OS & editor
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/

# Package manager lock files — uncomment the ones you do NOT use
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
dist/
dist-ssr/
.vite/

# -----------------------------------------------------------------------------
# Build output (shared)
# -----------------------------------------------------------------------------
build/

# -----------------------------------------------------------------------------
# Test & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
.env/
ENV/

# Distribution / packaging
*.egg
*.egg-info/
dist/
.eggs/
wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Test & lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/
htmlcov/
.coverage
.coverage.*

# Jupyter
.ipynb_checkpoints/
*.ipynb

# pyenv / poetry
.python-version
